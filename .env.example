# Copy to .env.local for local development, set in your platform for production.

# Default admin user (created on first run if doesn't exist)
ADMIN_EMAIL=admin@local
ADMIN_PASSWORD=admin1234

# Secret used to sign session cookies. Use a random string >= 32 chars in production.
# Generate one: openssl rand -hex 32
SESSION_SECRET=please-change-in-production-min-32-chars-long-random

# Optional: custom SQLite database path (defaults to ./data/app.db)
# DB_PATH=/var/data/partnership.db

# Set to "1" to disable login screen (useful for local dev only).
DISABLE_AUTH=0

# Optional: SMTP for sending actual outreach emails.
# If not set, outreach module only generates CSV (no real sending).
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=0       # set to 1 if port 465
# SMTP_USER=user@example.com
# SMTP_PASS=...
# SMTP_FROM="منصة الشراكات <noreply@example.com>"
