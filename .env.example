# Copy to .env.local for local development, set in your platform for production.

# Password to log in to the platform.
ADMIN_PASSWORD=admin1234

# Secret used to sign session cookies. Use a random string >= 32 chars.
SESSION_SECRET=please-change-in-production-min-32-chars

# Set to "1" to disable login screen (useful for local dev only).
DISABLE_AUTH=0
